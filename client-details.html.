<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Client Details | Bejja Credit</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">


<style>

body{

background:#eef4ff;
font-family:Segoe UI,sans-serif;

}


.header{

background:#0F4C81;
color:white;
padding:20px;

}


.card{

border:none;
border-radius:18px;
box-shadow:0 8px 25px rgba(0,0,0,.1);

}


.profile-img{

width:150px;
height:150px;
border-radius:50%;
object-fit:cover;
border:5px solid #0F4C81;

}


.label{

font-weight:bold;
color:#0F4C81;

}


.document-img{

width:100%;
height:220px;
object-fit:contain;
border:1px solid #ddd;
border-radius:12px;
background:#fafafa;

}


.section-title{

background:#0F4C81;
color:white;
padding:12px;
border-radius:10px;
margin-bottom:20px;

}


</style>


</head>


<body>


<div class="header">

<div class="container-fluid d-flex justify-content-between">

<h2>
<i class="fa fa-user"></i>
Client Details
</h2>


<a href="registered-clients.html" class="btn btn-light">

<i class="fa fa-arrow-left"></i>

Back

</a>


</div>

</div>



<div class="container mt-4">


<div id="clientArea"></div>


</div>





<script src="assets/js/database.js"></script>


<script>


const params = new URLSearchParams(window.location.search);

const id = Number(params.get("id"));



const client = DB.getClientById(id);



const area=document.getElementById("clientArea");



if(!client){


area.innerHTML=`

<div class="alert alert-danger">

Client not found.

</div>

`;


}else{



area.innerHTML=`


<div class="card p-4">


<div class="text-center">


<img

src="${client.profilePhoto}"

class="profile-img">


<h3 class="mt-3">

${client.fullname}

</h3>


<span class="badge bg-success">

${client.status}

</span>


</div>




<hr>




<h4 class="section-title">

Personal Information

</h4>


<div class="row">


<div class="col-md-6 mb-3">

<span class="label">

Client ID:

</span>

BC${String(client.id).padStart(6,"0")}

</div>



<div class="col-md-6 mb-3">

<span class="label">

National ID:

</span>

${client.nationalID}

</div>



<div class="col-md-6 mb-3">

<span class="label">

Phone:

</span>

${client.phone}

</div>



<div class="col-md-6 mb-3">

<span class="label">

Email:

</span>

${client.email || "Not provided"}

</div>



<div class="col-md-6 mb-3">

<span class="label">

Occupation:

</span>

${client.occupation}

</div>



<div class="col-md-6 mb-3">

<span class="label">

Employer:

</span>

${client.employer || "Not provided"}

</div>



<div class="col-md-6 mb-3">

<span class="label">

Monthly Income:

</span>

KES ${Number(client.monthlyIncome).toLocaleString()}

</div>



<div class="col-md-6 mb-3">

<span class="label">

County:

</span>

${client.county}

</div>



<div class="col-12 mb-3">

<span class="label">

Physical Address:

</span>

<br>

${client.address}

</div>



<div class="col-md-6 mb-3">

<span class="label">

Registered:

</span>

${client.createdAt}

</div>


</div>




<hr>



<h4 class="section-title">

Verification Documents

</h4>



<div class="row">


<div class="col-md-4">

<h6>
Profile Photo
</h6>

<img src="${client.profilePhoto}" class="document-img">

</div>



<div class="col-md-4">

<h6>

National ID Front

</h6>

<img src="${client.idFront}" class="document-img">

</div>




<div class="col-md-4">

<h6>

National ID Back

</h6>

<img src="${client.idBack}" class="document-img">

</div>


</div>




<hr>



<h4 class="section-title">

Loan Summary

</h4>



<div class="row text-center">


<div class="col-md-4">

<div class="card p-3">

<h5>
Total Loans
</h5>

<h3>

0

</h3>

</div>

</div>



<div class="col-md-4">

<div class="card p-3">

<h5>
Active Loan

</h5>

<h3>

No

</h3>

</div>

</div>



<div class="col-md-4">

<div class="card p-3">

<h5>
Outstanding

</h5>

<h3>

KES 0

</h3>

</div>

</div>



</div>



</div>


`;

}


</script>



</body>

</html>
